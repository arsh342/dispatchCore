# Server
NODE_ENV=development
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dispatch_core
DB_USER=root
DB_PASS=
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=
DB_SSL_REJECT_UNAUTHORIZED=true

# WebSocket
WS_CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_URL=http://localhost:5173

# Map Tiles (optional)
MAPTILER_API_KEY=

# Maintenance mode (for cutovers)
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_TOKEN=

# JWT Authentication (CE-02)
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-strong-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-strong-random-secret-at-least-32-chars
